<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg"
    android:padding="28dp">

    <TextView
        android:id="@+id/btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:paddingVertical="6dp"
        android:paddingEnd="20dp"
        android:text="‹ 返回"
        android:textColor="@color/accent"
        android:textSize="18sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="设置"
        android:textColor="@color/txt"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/row_community"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:background="@drawable/card_bg"
        android:padding="22dp"
        android:text="共创广场 · 设备配置导入 / 分享"
        android:textColor="@color/txt"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/row_account"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/card_bg"
        android:padding="22dp"
        android:text="米家账号"
        android:textColor="@color/txt"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/card_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="22dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="触发反馈"
                android:textColor="@color/txt"
                android:textSize="18sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="按键触发时短震动 + 屏幕提示"
                android:textColor="@color/sub"
                android:textSize="14sp" />
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_feedback"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/card_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="22dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="车外喊话"
                android:textColor="@color/txt"
                android:textSize="18sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="麦克风实时喊向车外喇叭 · 录音仅即时播放，不保存、不上传"
                android:textColor="@color/sub"
                android:textSize="14sp" />
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_exterior"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <TextView
        android:id="@+id/row_capture"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/card_bg"
        android:padding="22dp"
        android:text="抓包助手 · 实时打印广播 / 解密事件编码"
        android:textColor="@color/txt"
        android:textSize="18sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="关于"
        android:textColor="@color/sub"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/about_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:lineSpacingExtra="5dp"
        android:text="蓝牙按键 · 把各种蓝牙按键 / 旋钮接成可编程的车控遥控。设备配置采用声明式共创格式，可导入他人抓取的配置，也可分享自己的配置。账号凭据不落盘、不上传。"
        android:textColor="@color/sub"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/version_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/sub"
        android:textSize="14sp" />
</LinearLayout>
